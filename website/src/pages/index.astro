---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <header class="relative flex h-dvh flex-col items-center justify-center gap-6 px-6 text-center overflow-hidden" style="background-color:#956ab1">
    <canvas id="symbol-canvas" class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"></canvas>
    <img src="/miso/hero.svg" alt="Miso" class="relative w-64 sm:w-80 md:w-96 lg:w-xl" />
    <div class="relative mt-8 flex gap-8">
      <a href="https://github.com/hex-mt/miso"
         class="flex items-center gap-4 rounded-full bg-white px-10 pt-3 pb-4 font-daruma text-3xl leading-none text-[#3c6ec8] transition-colors hover:bg-[#22b6e4] hover:text-white [&_svg]:fill-[#3c6ec8] [&_svg]:transition-colors hover:[&_svg]:fill-white [box-shadow:0_5px_0_rgba(0,0,0,0.25)]">
