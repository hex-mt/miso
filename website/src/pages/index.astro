---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <header class="relative flex h-dvh flex-col items-center justify-center gap-6 px-6 text-center overflow-hidden" style="background-color:#956ab1">
    <canvas id="symbol-canvas" class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"></canvas>
    <img src="/miso/hero.svg" alt="Miso" class="relative w-64 sm:w-80 md:w-96 lg:w-xl" />
  </header>

  <script>
    const canvas = document.getElementById('symbol-canvas') as HTMLCanvasElement;
    const header = canvas.parentElement!;
    const ctx    = canvas.getContext('2d')!;
    const dpr    = Math.min(devicePixelRatio, 2);
    const tilePx = 450 * dpr; // base rasterisation size (matches default/sm banner width scale)

    // Mirror the banner's Tailwind breakpoints: w-64 → sm:w-80 → md:w-96 → lg:w-xl
    // lg (576px) is the reference — scale down for smaller viewports.
    function tileScale(): number {
      const w = window.innerWidth;
      if (w >= 1024) return 1;           // lg:  w-xl  = 36rem (reference)
      if (w >= 768)  return 384 / 576;   // md:  w-96
      if (w >= 640)  return 320 / 576;   // sm:  w-80
      return 256 / 576;                  // base: w-64
    }

    // Pre-compute rotation components once
    const ang  = -16.1 * Math.PI / 180;
    const cosA = Math.cos(ang);
    const sinA = Math.sin(ang);

    let drawFn: (() => void) | null = null;

    function resize() {
      canvas.width  = Math.round(header.clientWidth  * dpr);
      canvas.height = Math.round(header.clientHeight * dpr);
      drawFn?.();
    }
    resize();
    window.addEventListener('resize', resize);

    // Rasterise the SVG tile once into an offscreen canvas, then keep it as a GPU-cached pattern
    const img = new Image();
    img.src = '/miso/symbols.svg';
    img.onload = () => {
      const offscreen = document.createElement('canvas');
      offscreen.width  = tilePx;
      offscreen.height = tilePx;
      offscreen.getContext('2d')!.drawImage(img, 0, 0, tilePx, tilePx);

      const pattern = ctx.createPattern(offscreen, 'repeat')!;
      let cx = 0, cy = 0;

      drawFn = () => {
        const s = tileScale();
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        // Combine scale + rotation into one matrix; translate in physical pixels
        pattern.setTransform(new DOMMatrix([
           s * cosA,  s * sinA,
          -s * sinA,  s * cosA,
          cx * dpr,  cy * dpr,
        ]));
        ctx.globalAlpha = 0.35;
        ctx.fillStyle   = pattern;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
      };
      drawFn();

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reducedMotion) {
        let tx = 0, ty = 0, rafId: number | null = null;

        function tick() {
          const dx = tx - cx, dy = ty - cy;
          cx += dx * 0.07;
          cy += dy * 0.07;
          drawFn!();
          rafId = (Math.abs(dx) > 0.05 || Math.abs(dy) > 0.05)
            ? requestAnimationFrame(tick)
            : null;
        }

        window.addEventListener('mousemove', (e) => {
          tx = (e.clientX / window.innerWidth  - 0.5) * 40;
          ty = (e.clientY / window.innerHeight - 0.5) * 40;
          if (!rafId) rafId = requestAnimationFrame(tick);
        });
      }
    };
  </script>

