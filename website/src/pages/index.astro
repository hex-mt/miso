        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 98 96" class="h-6 w-6 shrink-0 translate-y-1 fill-white" aria-hidden="true">
          <path d="M49 1a49 49 0 0 0-15.5 95.5c2.5.5 3.4-1 3.4-2.3v-9c-13.7 3-16.6-5.9-16.6-5.9-2.2-5.7-5.5-7.2-5.5-7.2-4.5-3 .3-3 .3-3 5 .4 7.6 5.1 7.6 5.1 4.4 7.5 11.5 5.3 14.3 4.1.4-3.2 1.7-5.3 3.1-6.5-10.9-1.2-22.4-5.5-22.4-24.3 0-5.4 1.9-9.8 5-13.2-.5-1.3-2.2-6.3.5-13 0 0 4.1-1.3 13.4 5a46.3 46.3 0 0 1 24.4 0c9.3-6.3 13.4-5 13.4-5 2.7 6.7 1 11.7.5 13 3.1 3.4 5 7.8 5 13.2 0 18.9-11.5 23-22.4 24.2 1.7 1.5 3.3 4.5 3.3 9v13.4c0 1.3.8 2.8 3.4 2.3A49 49 0 0 0 49 1z"/>
        </svg>
      </a>
      <a href="https://discord.gg/8pfwVQCf33"
         class="flex items-center gap-4 rounded-full bg-white px-10 pt-3 pb-4 font-daruma text-3xl leading-none text-[#3c6ec8] transition-colors hover:bg-[#22b6e4] hover:text-white [&_svg]:fill-[#3c6ec8] [&_svg]:transition-colors hover:[&_svg]:fill-white [box-shadow:0_5px_0_rgba(0,0,0,0.25)]">
        Discord
        <!-- Discord mark -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 127.14 96.36" class="h-6 w-6 shrink-0 translate-y-1 fill-white" aria-hidden="true">
          <path d="M107.7 8.07A105.2 105.2 0 0 0 81.47 0a72.1 72.1 0 0 0-3.36 6.83 97.7 97.7 0 0 0-29.21 0A72.1 72.1 0 0 0 45.54 0a105.9 105.9 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.7 105.7 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.4 68.4 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.6 75.6 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.7 68.7 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.2 105.2 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.14zM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.1 12.69-11.44 12.69zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.1 12.69-11.43 12.69z"/>
        </svg>
      </a>
    </div>
  </header>

  <script>
    const canvas = document.getElementById('symbol-canvas') as HTMLCanvasElement;
    const header = canvas.parentElement!;
    const ctx    = canvas.getContext('2d')!;
    const dpr    = Math.min(devicePixelRatio, 2);
    const tilePx = 450 * dpr; // base rasterisation size (matches default/sm banner width scale)

    // Mirror the banner's Tailwind breakpoints: w-64 → sm:w-80 → md:w-96 → lg:w-xl
    // lg (576px) is the reference — scale down for smaller viewports.
    function tileScale(): number {
      const w = window.innerWidth;
      if (w >= 1024) return 1;           // lg:  w-xl  = 36rem (reference)
      if (w >= 768)  return 384 / 576;   // md:  w-96
      if (w >= 640)  return 320 / 576;   // sm:  w-80
      return 256 / 576;                  // base: w-64
    }

    // Pre-compute rotation components once
    const ang  = -16.1 * Math.PI / 180;
    const cosA = Math.cos(ang);
    const sinA = Math.sin(ang);

    let drawFn: (() => void) | null = null;

    function resize() {
      canvas.width  = Math.round(header.clientWidth  * dpr);
      canvas.height = Math.round(header.clientHeight * dpr);
      drawFn?.();
    }
    resize();
    window.addEventListener('resize', resize);

    // Rasterise the SVG tile once into an offscreen canvas, then keep it as a GPU-cached pattern
    const img = new Image();
    img.src = '/miso/symbols.svg';
    img.onload = () => {
      const offscreen = document.createElement('canvas');
      offscreen.width  = tilePx;
      offscreen.height = tilePx;
      offscreen.getContext('2d')!.drawImage(img, 0, 0, tilePx, tilePx);

      const pattern = ctx.createPattern(offscreen, 'repeat')!;
      let cx = 0, cy = 0;

      drawFn = () => {
        const s = tileScale();
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        // Combine scale + rotation into one matrix; translate in physical pixels
        pattern.setTransform(new DOMMatrix([
           s * cosA,  s * sinA,
          -s * sinA,  s * cosA,
          cx * dpr,  cy * dpr,
        ]));
        ctx.globalAlpha = 0.35;
        ctx.fillStyle   = pattern;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
      };
      drawFn();

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reducedMotion) {
        let tx = 0, ty = 0, rafId: number | null = null;

        function tick() {
          const dx = tx - cx, dy = ty - cy;
          cx += dx * 0.07;
          cy += dy * 0.07;
          drawFn!();
          rafId = (Math.abs(dx) > 0.05 || Math.abs(dy) > 0.05)
            ? requestAnimationFrame(tick)
            : null;
        }

        window.addEventListener('mousemove', (e) => {
          tx = (e.clientX / window.innerWidth  - 0.5) * 40;
          ty = (e.clientY / window.innerHeight - 0.5) * 40;
          if (!rafId) rafId = requestAnimationFrame(tick);
        });
      }
    };
  </script>

